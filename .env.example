# Copia este archivo como .env y agrega tus claves

# Google Maps — habilita "Maps JavaScript API", "Places API (New)" y "Geocoding API"
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_aqui
VITE_GOOGLE_MAPS_MAP_ID=tu_map_id_aqui   # opcional, crea uno en Cloud Console → Maps → Map IDs

# Anthropic (módulo legacy ResumenIA — opcional)
VITE_ANTHROPIC_API_KEY=tu_api_key_aqui

# n8n webhook para chatbot RAG (opcional — usa mock si no está definido)
VITE_N8N_WEBHOOK_URL=https://tu-instancia-n8n.com/webhook/...
